<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
        App Sandbox DISABLED:
        Required because ScreenCaptureKit and Carbon RegisterEventHotKey
        both need entitlements incompatible with the default sandbox profile.
        For Mac App Store distribution you would need to re-enable the sandbox
        and use SCContentSharingPicker + accessibility entitlements instead.
    -->
    <key>com.apple.security.app-sandbox</key>
    <false/>

    <!-- Allow outbound HTTPS for AI API calls -->
    <key>com.apple.security.network.client</key>
    <true/>
</dict>
</plist>
